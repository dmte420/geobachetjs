{
  "expo": {
    "name": "GeoBachetj",
    "slug": "geobachetj",
    "scheme": "exp+geobachetjs",
    "version": "2.1.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B1E3D"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GeoBache TJ usa tu ubicación para mostrar baches cercanos.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Necesitamos acceso a la cámara para tomar foto del bache.",
          "photosPermission": "No usaremos galería, solo cámara."
        }
      ],
      "expo-asset",
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "cmake": {
              "version": "3.22.1"
            }
          }
        }
      ]
    ],
    "android": {
      "package": "com.dmte420.geobachetjs.G1",
      "versionCode": 33,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundColor": "#0B1E3D"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.dmte420.geobachetjs.v2",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GeoBache TJ usa tu ubicación para mostrar baches cercanos y centrar el mapa.",
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para tomar foto del bache."
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "87bc312a-bef7-4786-a998-a44b4e97a682"
      }
    }
  }
}