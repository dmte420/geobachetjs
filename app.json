{
  "expo": {
    "name": "geobachetjs",
    "slug": "geobachetjs",
    "version": "2.153",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B1E3D"
    },
    "android": {
      "package": "com.dmte420.geobachetj.G1",
      "versionCode": 25,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundColor": "#0B1E3D"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.dmte420.geobachetj.v2",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "GeoBache TJ necesita acceso a tu cámara para tomar fotos de los baches que reportes.",
        "NSLocationWhenInUseUsageDescription": "GeoBache TJ usa tu ubicación para mostrar baches cercanos y centrar el mapa.",
        "NSPhotoLibraryUsageDescription": "GeoBache TJ necesita acceso a tu galería para seleccionar fotos de baches."
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "La app necesita acceso a tu cámara para reportar baches.",
          "photosPermission": "La app necesita acceso a tu galería para seleccionar fotos de baches."
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GeoBache TJ usa tu ubicación para alertas de baches en tu ruta.",
          "locationWhenInUsePermission": "GeoBache TJ usa tu ubicación para mostrar baches cercanos.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "kotlinVersion": "2.0.21",
            "extraMavenRepos": [
              "https://maven.pkg.github.com/maplibre/maplibre-native"
            ],
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "**/libjsc.so"
              ],
              "exclude": [
                "META-INF/DEPENDENCIES",
                "META-INF/LICENSE",
                "META-INF/NOTICE",
                "META-INF/LICENSE.txt",
                "META-INF/NOTICE.txt"
              ]
            }
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "2a0855bb-9fa9-4a67-affa-263dfb197a44"
      }
    }
  }
}
